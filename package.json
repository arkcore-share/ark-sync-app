{
  "name": "sync-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "cross-env NO_SANDBOX=1 node ./node_modules/electron-vite/bin/electron-vite.js dev",
    "build": "node ./node_modules/electron-vite/bin/electron-vite.js build",
    "preview": "cross-env NO_SANDBOX=1 node ./node_modules/electron-vite/bin/electron-vite.js preview",
    "package": "npm run build && electron-builder",
    "dev:win": "npm run dev",
    "electron:install": "node ./node_modules/electron/install.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "net.syncthing.sync-web",
    "productName": "Syncthing Sync Web",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
