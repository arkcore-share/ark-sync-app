{
  "_description": "智能体页扫描规则：修改后保存，在客户端内刷新智能体列表即可重新加载（无需重新编译）。打包后文件位于安装目录 resources 下，亦可直接编辑。",
  "claude-code": {
    "id": "claude-code",
    "dataRootCandidates": [
      { "kind": "home", "segments": [".claude"] }
    ],
    "dataPresentIfAny": [
      { "kind": "home", "segments": [".claude"] },
      { "kind": "home", "segments": [".claude.json"] }
    ],
    "skills": [
      {
        "base": "home",
        "segments": [".claude", "skills"],
        "enumerate": true,
        "maxEntries": 100,
        "enumerateLabelPrefix": "skills"
      },
      {
        "base": "home",
        "segments": [".claude", "agents"],
        "enumerate": true,
        "maxEntries": 100,
        "enumerateLabelPrefix": "agents"
      },
      {
        "base": "home",
        "segments": [".claude", "commands"],
        "enumerate": true,
        "maxEntries": 100,
        "enumerateLabelPrefix": "commands"
      }
    ],
    "memory": [
      {
        "base": "home",
        "segments": [".claude", "history"],
        "enumerate": true,
        "maxEntries": 48,
        "enumerateLabelPrefix": "history"
      },
      {
        "base": "home",
        "segments": [".claude", "index"],
        "enumerate": true,
        "maxEntries": 48,
        "enumerateLabelPrefix": "index"
